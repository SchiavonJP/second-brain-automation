# Domínio base — todos os subdomínios saem daqui
DOMAIN=your-domain.com

# Email para Let's Encrypt (certificados TLS)
ACME_EMAIL=your-email@example.com

# Basic auth para o dashboard do Traefik
# Gera com: echo $(htpasswd -nb admin tua_senha) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$XXXXXXXX$$XXXXXXXXXXXXXXXXXXXXXXXX

# Cloudflare DNS API token (Zone → DNS → Edit)
CF_DNS_API_TOKEN=your_cloudflare_dns_api_token
