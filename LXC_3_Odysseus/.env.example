# Odysseus deployment overrides
# Copy to ~/repo/.env on LXC 3 (inside the Odysseus repo directory)

# Bind to all interfaces — required for reverse proxy / cloudflared access
APP_BIND=0.0.0.0
APP_PORT=7000

# Set true when serving through HTTPS (Cloudflare Tunnel)
SECURE_COOKIES=true

# Pre-seed admin password (only applied on first boot with clean data)
ODYSSEUS_ADMIN_PASSWORD=change_me_before_first_boot

# LiteLLM router on LXC 4 (configure in Settings UI after login)
# LLM_HOST=192.168.0.211:4000

# Project name for Docker Compose container naming
COMPOSE_PROJECT_NAME=odysseus
