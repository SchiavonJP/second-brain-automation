# LiteLLM — chaves de segurança
# LITELLM_MASTER_KEY deve começar com sk-
LITELLM_MASTER_KEY=sk-your_master_key_here

LITELLM_SALT_KEY=your_random_hex_salt_64_chars

# Postgres no LXC 5 — database dedicado ao LiteLLM
DATABASE_URL=postgresql://secondbrain:your_postgres_password@192.168.0.210:5432/secondbrain

# Redis no LXC 5
REDIS_URL=redis://:your_redis_password@192.168.0.210:6379

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
