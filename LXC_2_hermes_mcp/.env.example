# LiteLLM — chave do LXC 4 (mesma do router)
LITELLM_MASTER_KEY=sk-your_litellm_master_key_here

# Dashboard do Hermes
HERMES_DASHBOARD_USER=admin
HERMES_DASHBOARD_PASSWORD=your_dashboard_password
HERMES_DASHBOARD_SECRET=your_random_hex_secret_64_chars

# Postgres no LXC 5
POSTGRES_USER=secondbrain
POSTGRES_PASSWORD=your_postgres_password

# Telegram (opcional — para aceder ao Hermes via Telegram)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
