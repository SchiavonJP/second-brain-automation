# Apollo — llama-server environment
# Copy to .env and adjust before running setup.sh
# setup.sh sources this file; values are written to /etc/llama-server.env

# OpenAI-compatible API port
LLAMA_PORT=8080

# Absolute path to the GGUF model file
LLAMA_MODEL_PATH=/models/Qwen3.6-35B-A3B-MTP-Q4_K_M.gguf

# Context window in tokens (16K = good for coding; 32K needs --ngl ~60 to free VRAM)
LLAMA_CTX_SIZE=16384

# GPU layers to offload (99 = max; lower to free VRAM for larger context)
LLAMA_NGL=99
