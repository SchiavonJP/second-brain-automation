# Apollo — llama-server environment
# Copy to .env and adjust before running setup.sh
# setup.sh sources this file; values are written to /etc/llama-server.env

# OpenAI-compatible API port
LLAMA_PORT=8080

# Absolute path to the GGUF model file
LLAMA_MODEL_PATH=/models/Qwen3.6-35B-A3B-MTP-Q4_K_M.gguf

# Context window in tokens
# 32K = sweet spot for coding (fits in 48GB RAM without reducing NGL)
# 64K = large codebase; add --rope-scaling yarn --rope-scale 2.0 to the service flags
# 128K = add --rope-scale 4.0; quality degrades beyond native 32K
LLAMA_CTX_SIZE=32768

# GPU layers to offload (99 = max; KV cache overflows to RAM automatically — no need to lower)
LLAMA_NGL=99
